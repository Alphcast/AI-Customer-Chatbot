{
  "__inputs": [],
  "__requires": [],
  "title": "AI Chatbot Platform - Production Overview",
  "uid": "ai-chatbot-platform-overview",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["ai-chatbot", "production", "platform"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"backend|frontend\"}[5m]))",
          "legendFormat": "Total Requests/sec"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Average Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))",
          "legendFormat": "p95 Latency"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"backend\", status=~\"5\\\\d{2}\"}[5m])) / sum(rate(http_requests_total{job=\"backend\"}[5m])) * 100",
          "legendFormat": "Error Rate %"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Conversations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_active_conversations)",
          "legendFormat": "Active Conversations"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "AI Token Usage (Today)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(chatbot_ai_token_usage_total[24h]))",
          "legendFormat": "Total Tokens"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1000000 },
              { "color": "red", "value": 5000000 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_queue_depth)",
          "legendFormat": "Queue Depth"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(rate(container_cpu_usage_seconds_total{namespace=\"chatbot-platform\"}[5m])) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Memory Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(container_memory_working_set_bytes{namespace=\"chatbot-platform\"}) / 1024 / 1024",
          "legendFormat": "Memory MB"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "MB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1024 },
              { "color": "red", "value": 2048 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "HTTP Request Rate (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"backend\"}[5m])) by (method, endpoint)",
          "legendFormat": "{{ method }} {{ endpoint }}"
        }
      ],
      "options": { "legend": { "calcs": ["max", "avg"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 10,
      "title": "Request Latency (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } } }
    },
    {
      "id": 11,
      "title": "HTTP Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"backend\", status=~\"5\\\\d{2}\"}[5m])) by (endpoint) / sum(rate(http_requests_total{job=\"backend\"}[5m])) by (endpoint) * 100",
          "legendFormat": "{{ endpoint }}"
        }
      ],
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "bars" } } }
    },
    {
      "id": 12,
      "title": "AI Token Usage by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(chatbot_ai_token_usage_total[5m])) by (model, type)",
          "legendFormat": "{{ model }} - {{ type }}"
        }
      ],
      "options": { "legend": { "calcs": ["max", "sum"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 13,
      "title": "Active Conversations Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_active_conversations) by (status)",
          "legendFormat": "{{ status }}"
        }
      ],
      "options": { "legend": { "calcs": ["max", "avg"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "id": 14,
      "title": "Bull Queue Depth by Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_queue_depth) by (queue)",
          "legendFormat": "{{ queue }}"
        },
        {
          "expr": "sum(chatbot_queue_waiting) by (queue)",
          "legendFormat": "{{ queue }} - Waiting"
        },
        {
          "expr": "sum(chatbot_queue_active) by (queue)",
          "legendFormat": "{{ queue }} - Active"
        },
        {
          "expr": "sum(chatbot_queue_failed) by (queue)",
          "legendFormat": "{{ queue }} - Failed"
        }
      ],
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line" } } }
    },
    {
      "id": 15,
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"chatbot-platform\"}[5m]) * 100",
          "legendFormat": "{{ pod }} - {{ container }}"
        }
      ],
      "options": { "legend": { "calcs": ["max", "avg"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line" } } }
    },
    {
      "id": 16,
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"chatbot-platform\"} / 1024 / 1024",
          "legendFormat": "{{ pod }} - {{ container }}"
        }
      ],
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "MB", "custom": { "drawStyle": "line" } } }
    },
    {
      "id": 17,
      "title": "Sentiment Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_conversations_by_sentiment) by (sentiment)",
          "legendFormat": "{{ sentiment }}"
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "reduceOptions": { "values": false, "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 18,
      "title": "Channel Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_conversations_by_channel) by (channel)",
          "legendFormat": "{{ channel }}"
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 19,
      "title": "AI Provider Usage",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_ai_requests_total) by (provider)",
          "legendFormat": "{{ provider }}"
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 20,
      "title": "Kubernetes Pod Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kube_pod_status_phase{namespace=\"chatbot-platform\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": {}, "indexByName": {}, "renameByName": {
          "pod": "Pod",
          "namespace": "Namespace",
          "phase": "Phase",
          "Value": "Count"
        }}}
      ],
      "options": { "footer": { "show": false }, "frameIndex": 0, "showTypeIcons": false },
      "fieldConfig": { "defaults": { "custom": { "align": "left" } } }
    },
    {
      "id": 21,
      "title": "SLA Compliance (Last 24h)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(chatbot_sla_compliant_total) / (sum(chatbot_sla_compliant_total) + sum(chatbot_sla_violations_total)) * 100",
          "legendFormat": "SLA %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Database Connections",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{namespace=\"chatbot-platform\"}",
          "legendFormat": "Active Connections"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line" } } }
    },
    {
      "id": 23,
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Used (MB)"
        },
        {
          "expr": "redis_memory_max_bytes / 1024 / 1024",
          "legendFormat": "Max (MB)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MB", "custom": { "drawStyle": "line" } } }
    },
    {
      "id": 24,
      "title": "S3 Upload Count (Last 24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 14, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(chatbot_uploads_total[24h]))",
          "legendFormat": "Uploads"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "sparkline", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "rows": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": { "limit": 100, "matchAny": false, "tags": [], "type": "dashboard" },
        "type": "dashboard"
      }
    ]
  },
  "links": [
    { "title": "Kubernetes Dashboard", "url": "https://k8s.chatbot.example.com", "targetBlank": true },
    { "title": "Alertmanager", "url": "https://alertmanager.chatbot.example.com", "targetBlank": true },
    { "title": "Go to Application", "url": "https://chatbot.example.com", "targetBlank": true }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_namespace_labels, namespace)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "chatbot-platform", "value": "chatbot-platform" }
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)",
        "refresh": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  }
}
